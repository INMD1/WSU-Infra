# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@localhost:3306/wsu_server

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ─── ESXi / govc ─────────────────────────────────────────────────────────────
ESXI_MODE=govc                        # govc | rest

GOVC_URL=https://your-vcenter-or-esxi-host
GOVC_USERNAME=administrator@vsphere.local
GOVC_PASSWORD=your-password
GOVC_INSECURE=0                       # 1 = TLS 검증 비활성화 (개발용)
GOVC_DATACENTER=/                     # 예: ha-datacenter
GOVC_DATASTORE=                       # 기본 데이터스토어 (자동 선택 시 생략)
GOVC_NETWORK=Internal-VNIC
GOVC_RESOURCE_POOL=
GOVC_FOLDER=
DATASTORE_PREFIX=ds-                  # 자동 선택 시 이 접두사로 시작하는 DS만 대상

# ─── pfSense API ──────────────────────────────────────────────────────────────
PFSENSE_URL=https://your-pfsense-ip
PFSENSE_API_KEY=your-api-key
PFSENSE_API_CLIENT_ID=               # v1 인증 방식일 때만 필요 (client_id token 쌍)
PFSENSE_INSECURE=0                   # 1 = TLS 검증 비활성화 (개발용, 운영 금지)
PFSENSE_WAN_IP=1.2.3.4               # 응답에 표시할 외부(WAN) IP
PFSENSE_PORT_RANGE_START=10000       # 자동 배정 포트 범위 시작
PFSENSE_PORT_RANGE_END=20000         # 자동 배정 포트 범위 끝
