# MySQL 연결 설정
DATABASE_URL=mysql://user:password@localhost:3306/wsu_server

# ESXi 연동 모드 (govc 또는 rest)
ESXI_MODE=govc

# govc (ESXi CLI) 설정
GOVC_URL=your-esxi-host
GOVC_USERNAME=root
GOVC_PASSWORD=password
GOVC_INSECURE=true
GOVC_DATACENTER=ha-datacenter
GOVC_DATASTORE=datastore1
GOVC_NETWORK="VM Network"

# pfSense 연동 설정
PFSENSE_FAUXAPI_KEY=key_here
PFSENSE_FAUXAPI_SECRET=secret_here
PFSENSE_INSECURE=true


